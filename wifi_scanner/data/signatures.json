{
  "_comment": "Device fingerprint signatures. Each entry matches if ANY listed source contains ANY of its needles (case-insensitive substring). Sources: snmp_sysdescr, http, upnp, mdns, smb, netbios, banner, vendor. Optional fields: category, subcategory, os, vendor, model.",
  "signatures": [
